algoritmo "Nota"
// Disciplina : Lopal(Lógica de Programaçăo)

//F9(executar código)

// Autor :Lorena Oliveira e Caline Myrella
// Data : 14/04/2026

var
// Declaraçă de Variavéis
nota,frequencia:real

inicio
// Seçăo de Comandos
   escreva("digite a nota do aluno:" )
   leia(nota)
   
   escreva("digite a frequęncia do aluno:" )
   leia(frequencia)

   se (nota>=7) e (frequencia>=75) entao
   
   escreval("o aluno foi aprovado")
   
   
   senao
   escreval("o aluno foi reprovado")
   fimse
   

fimalgoritmo
