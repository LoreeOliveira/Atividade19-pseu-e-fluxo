algoritmo "entrada gratuita ingresso"
// Funçăo :LOPAL(Lógica de ´programaçăo)

// Autor :Caline e Lorena
// Data : 14/04/2026
// Seçăo de Declaraçőes 
var
 //Declaraçăo de variaveis
 
 idade:real
inicio
// Seçăo de Comandos

  escreva ("digite sua idade: ")
  leia(idade)
  
  se (idade < 5) ou (idade >=65) entao
  
  escreval ("entrada gratuita")
  senao
  escreval ("pagar o ingresso")
  fimse

 
fimalgoritmo
